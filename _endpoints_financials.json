        {
          "name": "companyId",
          "type": "uuid",
          "required": true,
          "description": "Company identifier"
        },
        {
          "name": "scenarioId",
          "type": "uuid",
          "required": false,
          "description": "Scenario identifier"
        },
        {
          "name": "versionId",
          "type": "uuid",
          "required": false,
          "description": "Version identifier"
        },
        {
          "name": "periodId",
          "type": "uuid",
          "required": false,
          "description": "Planning period identifier"
        },
        {
          "name": "scopeRef",
          "type": "uuid",
          "required": false,
          "description": "Scope bundle reference"
        }
      ],
      "path_params": []
    },
    "response_schema": {
      "success": {
        "status": 200,
        "body": {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "revenue": {
                  "type": "number"
                },
                "grossProfit": {
                  "type": "number"
                },
                "ebitda": {
                  "type": "number"
                },
                "netIncome": {
                  "type": "number"
                },
                "burn": {
                  "type": "number"
                },
                "runway": {
                  "type": "number"
                },
                "irr": {
                  "type": "number"
                },
                "periodLabel": {
                  "type": "string"
                }
              }
            },
            "meta": {
              "type": "object",
              "properties": {
                "freshness": {
                  "type": "string"
                },
                "governanceState": {
                  "type": "string"
                },
                "computeRunId": {
                  "type": "uuid"
                },
                "confidenceState": {
                  "type": "string"
                }
              }
